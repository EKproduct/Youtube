RAPIDAPI_KEY=
SERPAPI_KEY=

# YouTube cookie auth (needed when deployed — cloud/datacenter IPs get bot-detection blocked).
# Export cookies.txt from a logged-in browser session (Netscape format), e.g. via the
# "Get cookies.txt LOCALLY" browser extension, then use ONE of the following:

# Option A — local/Docker with a mounted file:
YOUTUBE_COOKIES_FILE=

# Option B — Railway/other platforms with no file upload: paste the cookies.txt contents
# directly (the app writes it to disk at startup). Takes precedence over YOUTUBE_COOKIES_FILE.
YOUTUBE_COOKIES_CONTENT=
